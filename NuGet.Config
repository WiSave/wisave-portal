<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="wisave" value="https://nuget.pkg.github.com/WiSave/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="wisave">
      <package pattern="WiSave.Expenses.*" />
      <package pattern="WiSave.Framework.*" />
      <package pattern="WiSave.Incomes.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
